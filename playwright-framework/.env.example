# Copy this file to .env and fill in values.
# .env is git-ignored — never commit real credentials.

# Environment selector: dev | qa | prod
TEST_ENV=qa

# Dev URLs
DEV_BASE_URL=https://dev.example.com
DEV_API_URL=https://api.dev.example.com
DEV_USER_EMAIL=test@dev.example.com
DEV_USER_PASSWORD=DevP@ss123

# QA URLs
QA_BASE_URL=https://qa.example.com
QA_API_URL=https://api.qa.example.com
QA_USER_EMAIL=test@qa.example.com
QA_USER_PASSWORD=QaP@ss123

# Prod URLs
PROD_BASE_URL=https://www.example.com
PROD_API_URL=https://api.example.com
PROD_USER_EMAIL=
PROD_USER_PASSWORD=

# Logging
LOG_LEVEL=info

# Report retention
REPORT_RETENTION_DAYS=7
